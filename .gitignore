# -----------------------------
# 1. 自動生成ファイル・ビルド成果物
# -----------------------------
# ビルド用フォルダ
build/
bin/

# コンパイルの中間ファイル (.o)
*.o

# エディタのバックアップファイル (末尾に~がつくもの)
*~

# 実行ファイル (拡張子なしの FlagRobot も含む)
FlagRobot
*.exe

# -----------------------------
# 2. 外部ライブラリ・バイナリ (重いファイル)
# -----------------------------
# ライブラリフォルダ
lib/

# DLLやLIBファイル (通常はGitに入れず、別途インストール等を案内する)
*.dll
*.lib

# -----------------------------
# 3. Python関連
# -----------------------------
# 仮想環境 (絶対にGitに入れない)
venv/

# Pythonのコンパイルキャッシュ
__pycache__/
*.pyc

# -----------------------------
# 4. 一時ファイル・ログ
# -----------------------------
# 音声生成の一時ファイル
temp_speech.mp3

# -----------------------------
# 5. 設定・機密情報
# -----------------------------
# VS Codeのローカル設定 (個人設定が含まれるため除外推奨)
.vscode/

# 機密情報 (前回の話題)
.env